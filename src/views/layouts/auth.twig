<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<meta name="description" content="ChronoFlow - Authentification">
		<title>
			{% block title %}ChronoFlow - Authentification
			{% endblock %}
		</title>

		<!-- CSS -->
		<link rel="stylesheet" href="/css/variables.css">
		<link rel="stylesheet" href="/css/layout.css">
		<link rel="stylesheet" href="/css/components.css">
		<link
		rel="stylesheet" href="/css/forms.css">

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

		<style>
			body {
				display: flex;
				align-items: center;
				justify-content: center;
				min-height: 100vh;
				background: linear-gradient(135deg, var(--color-bg) 0%, var(--color-primary-soft) 100%);
			}

			.auth-container {
				width: 100%;
				max-width: 400px;
				padding: var(--space-lg);
			}

			.auth-card {
				background-color: var(--color-surface);
				border-radius: var(--radius-md);
				padding: var(--space-xxl);
				box-shadow: var(--shadow-strong);
			}

			.auth-header {
				text-align: center;
				margin-bottom: var(--space-xxl);
			}

			.auth-logo {
				font-size: 32px;
				margin-bottom: var(--space-md);
			}

			.auth-title {
				font-size: var(--font-size-h2);
				font-weight: var(--font-weight-bold);
				color: var(--color-text-primary);
				margin-bottom: var(--space-sm);
			}

			.auth-subtitle {
				font-size: var(--font-size-body);
				color: var(--color-text-secondary);
			}
		</style>

		{% block head %}{% endblock %}
	</head>
	<body>
		<div class="auth-container">
			<div class="auth-card"> {% block content %}{% endblock %}
				</div>
			</div>

			<script src="/js/main.js" defer></script>
			{% block scripts %}{% endblock %}
		</body>
	</html>

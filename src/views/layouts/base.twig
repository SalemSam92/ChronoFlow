<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<meta name="description" content="ChronoFlow - Application de suivi de temps en temps réel">
		<title>
			{% block title %}ChronoFlow
			{% endblock %}
		</title>

		<!-- CSS -->
		<link rel="stylesheet" href="/css/variables.css">
		<link rel="stylesheet" href="/css/layout.css">
		<link rel="stylesheet" href="/css/components.css">
		<link
		rel="stylesheet" href="/css/forms.css">

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"> {% block head %}{% endblock %}
		</head>
		<body>
			<div
				class="layout-main">
				<!-- Sidebar -->
				{% include 'components/sidebar.twig' %}

				<!-- Main content -->
				<div
					class="content-wrapper">
					<!-- Header -->
					{% include 'components/header.twig' %}

					<!-- Page content -->
					<main class="content"> {% block content %}{% endblock %}
						</main>
					</div>
				</div>

				<!-- JavaScript -->
				<script src="/js/main.js" defer></script>
				{% block scripts %}{% endblock %}
			</body>
		</html>

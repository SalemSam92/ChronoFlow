<header class="header">
	<h2 class="header-title">
		{% block headerTitle %}ChronoFlow
		{% endblock %}
	</h2>

	<div class="header-search">
		<input type="text" placeholder="🔍 Rechercher..." style="width: 100%; padding: var(--space-md) var(--space-lg); border: var(--border-light); border-radius: var(--radius-sm); background-color: var(--color-surface-soft);">
	</div>

	<div class="header-actions">
		<button class="btn btn-ghost btn-sm" title="Notifications">
			🔔
		</button>

		<div class="header-avatar" title="Profil">
			JD
		</div>
	</div>
</header>

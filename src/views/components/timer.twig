<div class="card" style="text-align: center; padding: var(--space-xxl);">
	<div style="font-size: 72px; margin-bottom: var(--space-lg);">⏱️</div>
	<div style="font-size: 56px; font-weight: 700; color: var(--color-primary); margin-bottom: var(--space-md);">
		{{ time | default('24:42') }}
	</div>
	<div style="font-size: 14px; color: var(--color-text-secondary); margin-bottom: var(--space-xxl);">
		{{ status | default('Session de focus active') }}
	</div>
	<div style="display: flex; gap: var(--space-md); justify-content: center;">
		<button class="btn btn-secondary btn-lg">⏸️ Pause</button>
		<button class="btn btn-danger btn-lg">⏹️ Terminer</button>
	</div>
</div>

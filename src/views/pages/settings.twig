{% extends 'layouts/base.twig' %}

{% block title %}Paramètres — ChronoFlow
{% endblock %}

{% block content %}
	<div class="page-header">
		<h1 class="page-title">Paramètres</h1>
	</div>

	<div
		style="display: grid; grid-template-columns: 240px 1fr; gap: var(--space-xl);">
		<!-- Menu onglets -->
		<div style="display: flex; flex-direction: column; gap: var(--space-md);">
			<a href="#" style="padding: var(--space-md) var(--space-lg); border-radius: var(--radius-sm); background-color: var(--color-primary-soft); color: var(--color-primary); text-decoration: none; font-weight: 600;">👤 Profil</a>
			<a href="#" style="padding: var(--space-md) var(--space-lg); border-radius: var(--radius-sm); color: var(--color-text-secondary); text-decoration: none; font-weight: 600;">🏢 Espace de travail</a>
			<a href="#" style="padding: var(--space-md) var(--space-lg); border-radius: var(--radius-sm); color: var(--color-text-secondary); text-decoration: none; font-weight: 600;">🔔 Notifications</a>
			<a href="#" style="padding: var(--space-md) var(--space-lg); border-radius: var(--radius-sm); color: var(--color-text-secondary); text-decoration: none; font-weight: 600;">💳 Facturation</a>
		</div>

		<!-- Contenu -->
		<div>
			<section class="section">
				<h2 class="section-title">Profil utilisateur</h2>

				<div class="card">
					<div style="display: flex; align-items: center; gap: var(--space-lg); margin-bottom: var(--space-xxl);">
						<div class="header-avatar" style="width: 80px; height: 80px; font-size: 32px;">JD</div>
						<div>
							<button class="btn btn-secondary btn-sm">Modifier l'avatar</button>
							<p style="font-size: 12px; color: var(--color-text-secondary); margin-top: var(--space-sm);">JPG ou PNG, max 5MB</p>
						</div>
					</div>

					<form class="form">
						<div class="form-group">
							<label class="form-label required">Prénom</label>
							<input type="text" value="Julian" style="width: 100%; padding: var(--space-md) var(--space-lg); border: var(--border-light); border-radius: var(--radius-sm); background-color: var(--color-surface);">
						</div>

						<div class="form-group">
							<label class="form-label required">Nom</label>
							<input type="text" value="Dupont" style="width: 100%; padding: var(--space-md) var(--space-lg); border: var(--border-light); border-radius: var(--radius-sm); background-color: var(--color-surface);">
						</div>

						<div class="form-group">
							<label class="form-label required">E-mail</label>
							<input type="email" value="jean.dupont@acmecorp.com" style="width: 100%; padding: var(--space-md) var(--space-lg); border: var(--border-light); border-radius: var(--radius-sm); background-color: var(--color-surface);">
						</div>

						<div class="form-group">
							<label class="form-label">Biographie</label>
							<textarea style="width: 100%; padding: var(--space-md) var(--space-lg); border: var(--border-light); border-radius: var(--radius-sm); background-color: var(--color-surface); min-height: 100px;">Product Design Manager chez Acme Corp. Passionné par l'optimisation de la productivité.</textarea>
						</div>

						<button class="btn btn-primary">✓ Enregistrer les modifications</button>
					</form>
				</div>
			</section>

			<section class="section">
				<h2 class="section-title">Apparence</h2>

				<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-lg);">
					<div style="padding: var(--space-lg); border: 3px solid var(--color-primary); border-radius: var(--radius-md); text-align: center; background-color: var(--color-surface); cursor: pointer;">
						<div style="font-size: 32px; margin-bottom: var(--space-md);">☀️</div>
						<div style="font-weight: 600; color: var(--color-primary);">Clair</div>
					</div>

					<div style="padding: var(--space-lg); border: 3px solid var(--color-border); border-radius: var(--radius-md); text-align: center; background-color: var(--color-surface); cursor: pointer;">
						<div style="font-size: 32px; margin-bottom: var(--space-md);">🌙</div>
						<div style="font-weight: 600; color: var(--color-text-secondary);">Sombre</div>
					</div>

					<div style="padding: var(--space-lg); border: 3px solid var(--color-border); border-radius: var(--radius-md); text-align: center; background-color: var(--color-surface); cursor: pointer;">
						<div style="font-size: 32px; margin-bottom: var(--space-md);">🖥️</div>
						<div style="font-weight: 600; color: var(--color-text-secondary);">Système</div>
					</div>
				</div>
			</section>

			<section class="section">
				<h2 class="section-title">Seuil de détection d'inactivité</h2>

				<div class="card">
					<label class="form-label">Détection après (secondes)</label>
					<input type="range" min="60" max="1800" value="180" style="width: 100%; margin-top: var(--space-md);">
					<p style="margin-top: var(--space-md); font-size: 14px; color: var(--color-text-secondary);">
						Actuellement :
						<strong>3 minutes</strong>
					</p>
				</div>
			</section>

			<section class="section">
				<h2 class="section-title">Zone de danger</h2>

				<div class="card" style="border-left: 4px solid var(--color-danger);">
					<h4 style="color: var(--color-danger);">Désactiver le compte</h4>
					<p style="margin-top: var(--space-md); color: var(--color-text-secondary); margin-bottom: var(--space-lg);">Une fois désactivé, votre compte et toutes les données associées seront supprimées définitivement.</p>
					<button class="btn btn-danger">🗑️ Désactiver le compte</button>
				</div>
			</section>
		</div>
	</div>
{% endblock %}

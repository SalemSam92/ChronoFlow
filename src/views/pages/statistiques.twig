{% extends 'layouts/base.twig' %}

{% block title %}Statistiques — ChronoFlow
{% endblock %}

{% block content %}
	<div class="page-header">
		<h1 class="page-title">Statistiques</h1>
		<p class="page-subtitle">Suivez votre évolution et optimisez vos périodes de travail profond.</p>
	</div>

	<!-- KPIs -->
	<section class="section">
		<div class="grid grid-3">
			<div class="kpi-card">
				<div class="kpi-label">Focus total</div>
				<div class="kpi-value">124.5h</div>
				<span class="kpi-trend positive">+12%</span>
			</div>

			<div class="kpi-card">
				<div class="kpi-label">Tâches terminées</div>
				<div class="kpi-value">342</div>
				<span class="kpi-trend positive">+8%</span>
			</div>

			<div class="kpi-card">
				<div class="kpi-label">Série actuelle</div>
				<div class="kpi-value">14</div>
				<span class="kpi-trend positive">Jours</span>
			</div>
		</div>
	</section>

	<!-- Graphiques -->
	<section class="section">
		<div
			class="grid grid-2">
			<!-- Heures de Focus -->
			<div class="card">
				<div class="section-header">
					<h3 class="section-title">Heures de Focus</h3>
					<select style="padding: var(--space-sm) var(--space-md); border: var(--border-light); border-radius: var(--radius-sm); background-color: var(--color-surface-soft);">
						<option>Cette semaine</option>
						<option>Ce mois-ci</option>
						<option>Cette année</option>
					</select>
				</div>

				<div style="margin-top: var(--space-lg); display: flex; align-items: flex-end; gap: var(--space-md); height: 250px;">
					<div style="flex: 1; background: linear-gradient(to top, var(--color-primary) 40%, transparent 40%); border-radius: var(--radius-sm) var(--radius-sm) 0 0; position: relative;">
						<span style="position: absolute; bottom: -30px; left: 0; right: 0; text-align: center; font-size: 12px; color: var(--color-text-secondary);">Lun</span>
					</div>
					<div style="flex: 1; background: linear-gradient(to top, var(--color-primary) 65%, transparent 65%); border-radius: var(--radius-sm) var(--radius-sm) 0 0; position: relative;">
						<span style="position: absolute; bottom: -30px; left: 0; right: 0; text-align: center; font-size: 12px; color: var(--color-text-secondary);">Mar</span>
					</div>
					<div style="flex: 1; background: linear-gradient(to top, var(--color-primary) 45%, transparent 45%); border-radius: var(--radius-sm) var(--radius-sm) 0 0; position: relative;">
						<span style="position: absolute; bottom: -30px; left: 0; right: 0; text-align: center; font-size: 12px; color: var(--color-text-secondary);">Mer</span>
					</div>
					<div style="flex: 1; background: linear-gradient(to top, var(--color-primary) 78%, transparent 78%); border-radius: var(--radius-sm) var(--radius-sm) 0 0; position: relative;">
						<span style="position: absolute; bottom: -30px; left: 0; right: 0; text-align: center; font-size: 12px; color: var(--color-text-secondary);">Jeu</span>
					</div>
					<div style="flex: 1; background: linear-gradient(to top, var(--color-primary) 52%, transparent 52%); border-radius: var(--radius-sm) var(--radius-sm) 0 0; position: relative;">
						<span style="position: absolute; bottom: -30px; left: 0; right: 0; text-align: center; font-size: 12px; color: var(--color-text-secondary);">Ven</span>
					</div>
					<div style="flex: 1; background: linear-gradient(to top, var(--color-primary) 30%, transparent 30%); border-radius: var(--radius-sm) var(--radius-sm) 0 0; position: relative;">
						<span style="position: absolute; bottom: -30px; left: 0; right: 0; text-align: center; font-size: 12px; color: var(--color-text-secondary);">Sam</span>
					</div>
					<div style="flex: 1; background: linear-gradient(to top, var(--color-primary) 35%, transparent 35%); border-radius: var(--radius-sm) var(--radius-sm) 0 0; position: relative;">
						<span style="position: absolute; bottom: -30px; left: 0; right: 0; text-align: center; font-size: 12px; color: var(--color-text-secondary);">Dim</span>
					</div>
				</div>
			</div>

			<!-- Répartition -->
			<div class="card">
				<div class="section-header">
					<h3 class="section-title">Répartition</h3>
					<select style="padding: var(--space-sm) var(--space-md); border: var(--border-light); border-radius: var(--radius-sm); background-color: var(--color-surface-soft);">
						<option>Ce mois-ci</option>
						<option>Cette semaine</option>
						<option>Cette année</option>
					</select>
				</div>

				<div style="margin-top: var(--space-lg); display: flex; align-items: center; gap: var(--space-lg);">
					<svg width="160" height="160" style="flex-shrink: 0;">
						<circle cx="80" cy="80" r="60" fill="none" stroke="var(--color-primary)" stroke-width="18" stroke-dasharray="150 400" stroke-dashoffset="0"/>
						<circle cx="80" cy="80" r="60" fill="none" stroke="var(--color-secondary)" stroke-width="18" stroke-dasharray="100 400" stroke-dashoffset="-150"/>
						<circle cx="80" cy="80" r="60" fill="none" stroke="var(--color-success)" stroke-width="18" stroke-dasharray="80 400" stroke-dashoffset="-250"/>
						<circle cx="80" cy="80" r="60" fill="none" stroke="var(--color-disabled)" stroke-width="18" stroke-dasharray="70 400" stroke-dashoffset="-330"/>
					</svg>

					<div style="display: flex; flex-direction: column; gap: var(--space-md);">
						<div style="display: flex; align-items: center; gap: var(--space-md);">
							<div style="width: 12px; height: 12px; background: var(--color-primary); border-radius: 50%;"></div>
							<span>Coding 40%</span>
						</div>
						<div style="display: flex; align-items: center; gap: var(--space-md);">
							<div style="width: 12px; height: 12px; background: var(--color-secondary); border-radius: 50%;"></div>
							<span>Web 25%</span>
						</div>
						<div style="display: flex; align-items: center; gap: var(--space-md);">
							<div style="width: 12px; height: 12px; background: var(--color-success); border-radius: 50%;"></div>
							<span>Communication 20%</span>
						</div>
						<div style="display: flex; align-items: center; gap: var(--space-md);">
							<div style="width: 12px; height: 12px; background: var(--color-disabled); border-radius: 50%;"></div>
							<span>Idle 15%</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Insight -->
	<section class="section">
		<div class="card" style="background: linear-gradient(135deg, var(--color-primary-soft) 0%, var(--color-secondary-soft) 100%); border-left: 4px solid var(--color-primary);">
			<div class="section-header">
				<div>
					<h4>💡 Insight actionable</h4>
					<p style="margin-top: var(--space-md); color: var(--color-text-secondary);">Vous avez passé 45% de votre temps en réunions cette semaine, contre 35% en moyenne. Envisagez de bloquer des plages de focus ininterrompu.</p>
				</div>
				<button class="btn btn-primary">Optimiser</button>
			</div>
		</div>
	</section>

	<!-- Période et export -->
	<section class="section">
		<div style="display: flex; justify-content: space-between; align-items: center;">
			<select style="padding: var(--space-md) var(--space-lg); border: var(--border-light); border-radius: var(--radius-sm); background-color: var(--color-surface);">
				<option>Ce mois-ci</option>
				<option>Cette semaine</option>
				<option>Cette année</option>
			</select>

			<button class="btn btn-primary">📥 Exporter en PDF</button>
		</div>
	</section>
{% endblock %}

{% extends 'layouts/auth.twig' %}

{% block title %}Connexion — ChronoFlow
{% endblock %}

{% block content %}
	<div class="auth-header">
		<div class="auth-logo">⏱️</div>
		<h1 class="auth-title">ChronoFlow</h1>
		<p class="auth-subtitle">Concentrez-vous sur l'essentiel.</p>
	</div>

	<form class="form">
		<div style="display: flex; flex-direction: column; gap: var(--space-md);">
			<button type="button" class="btn btn-secondary" style="width: 100%;">
				<span>🔵</span>
				<span>Configurer avec Google</span>
			</button>
			<button type="button" class="btn btn-secondary" style="width: 100%;">
				<span>⚫</span>
				<span>Configurer avec GitHub</span>
			</button>
		</div>

		<div style="display: flex; align-items: center; gap: var(--space-md); margin: var(--space-lg) 0; color: var(--color-text-muted); font-size: 14px;">
			<div style="flex: 1; height: 1px; background-color: var(--color-border);"></div>
			<span>OU EMAIL</span>
			<div style="flex: 1; height: 1px; background-color: var(--color-border);"></div>
		</div>

		<div class="form-group">
			<label class="form-label required">Adresse e-mail</label>
			<input type="email" placeholder="nom@entreprise.com" style="width: 100%; padding: var(--space-md) var(--space-lg); border: var(--border-light); border-radius: var(--radius-sm); background-color: var(--color-surface);">
		</div>

		<div class="form-group">
			<label class="form-label required">Mot de passe</label>
			<input type="password" placeholder="••••••••" style="width: 100%; padding: var(--space-md) var(--space-lg); border: var(--border-light); border-radius: var(--radius-sm); background-color: var(--color-surface);">
		</div>

		<button type="submit" class="btn btn-primary" style="width: 100%;">Se connecter</button>
	</form>

	<div style="text-align: center; margin-top: var(--space-lg); color: var(--color-text-secondary); font-size: 14px;">
		Vous n'avez pas de compte ?
		<a href="#" style="color: var(--color-primary); font-weight: 600;">Créer un espace</a>
	</div>

	<div style="margin-top: var(--space-lg); padding-top: var(--space-lg); border-top: var(--border-light); text-align: center; color: var(--color-text-muted); font-size: 12px;">
		<a href="#" style="color: var(--color-text-muted); text-decoration: underline;">Politique de confidentialité</a>
		•
		<a href="#" style="color: var(--color-text-muted); text-decoration: underline;">Conditions d'utilisation</a>
	</div>
{% endblock %}
